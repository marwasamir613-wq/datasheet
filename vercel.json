{
  "version": 2,
  "framework": null,
  "installCommand": "echo no-install-needed",
  "buildCommand": "echo no-build-needed",
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/admin",
      "dest": "/admin.html",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow",
        "Cache-Control": "no-store"
      }
    },
    {
      "src": "/admin.html",
      "dest": "/admin.html",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow",
        "Cache-Control": "no-store"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/index.html" }
  ]
}
